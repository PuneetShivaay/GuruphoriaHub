/**
 * @fileoverview Firestore Security Rules for Guruphoria Courses.
 *
 * Core Philosophy:
 * This ruleset allows public read access to course information while restricting write access to authenticated users only.
 *
 * Data Structure:
 * All course data is stored in the top-level `/courses/{courseId}` collection.
 *
 * Key Security Decisions:
 * - Public read access is enabled for all courses.
 * - Only authenticated users can create, update, or delete courses. There is no concept of ownership, so any logged-in user can modify any course.
 *
 * Denormalization for Authorization:
 * No denormalization is needed as the rules are simple.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Grants public read access to courses, but restricts writes to authenticated users.
     * @path /courses/{courseId}
     * @allow (get, list) Any user can read course data.
     * @allow (create) An authenticated user can create a course.
     * @allow (update) An authenticated user can update a course.
     * @allow (delete) An authenticated user can delete a course.
     * @deny (create, update, delete) An unauthenticated user cannot modify course data.
     * @principle Allows public reads, restricts writes to authenticated users.
     */
    match /courses/{courseId} {
      allow get: if true;
      allow list: if true;

      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource != null;
      allow delete: if isSignedIn() && resource != null;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
  }
}